{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "node api/build.mjs && pnpm --filter @workspace/derech-hashemesh... build",
  "outputDirectory": "artifacts/derech-hashemesh/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/dist" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/dist/index.js": {
      "maxDuration": 30
    }
  }
}
